PORT=3001
BROWSER=none

# API Configuration
# URL base de la API REST
REACT_APP_API_URL=http://localhost:3000/api/v1

# URL para conexiones WebSocket (Socket.IO)
REACT_APP_SOCKET_URL=http://localhost:3000

# Notas:
# - Las variables REACT_APP_* son accesibles en el cliente
# - Cambia localhost por la IP del servidor en producción
# - Para desarrollo con dispositivos en red local usa tu IP: http://192.168.X.X:3000
